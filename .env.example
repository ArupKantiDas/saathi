# ===== Google Gemini API (PRIMARY LLM — free tier, no billing) =====
# Create at https://aistudio.google.com/ or via gcloud api-keys for generativelanguage.
GEMINI_API_KEY=your-gemini-api-key
# Ordered fallback chain (first that succeeds wins). flash + flash-lite are
# separate quota buckets, so a rate limit on one is survived by the next.
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-flash-latest

# ===== AWS Bedrock (OPTIONAL cross-cloud Claude fallback) =====
# Disabled unless BEDROCK_ENABLED=true. Requires the Anthropic "use case
# details" form approved on the AWS account before Claude can be invoked.
BEDROCK_ENABLED=false
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ===== Firebase (Auth + Firestore) =====
# Server-side: used to verify Firebase ID tokens (audience/issuer = project id).
FIREBASE_PROJECT_ID=your-project-id
# Client-side (safe to expose; Firestore rules are the real guard):
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
